# LLM provider abstraction — swap these two to change models (config-only).
# Examples: openai/gpt-4o, anthropic/claude-opus-4-8, ollama/llama3.1
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Provider key — set the standard env var for whichever provider you chose.
OPENAI_API_KEY=sk-your-key
# ANTHROPIC_API_KEY=...

# MCP server (FastMCP streamable-http) endpoint
MCP_URL=http://localhost:8001/mcp

# Allowed CORS origins (comma-separated) — the Vite dev server
CORS_ORIGINS=http://localhost:5173
